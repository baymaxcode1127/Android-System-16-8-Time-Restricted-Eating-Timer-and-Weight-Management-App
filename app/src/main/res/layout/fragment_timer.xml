<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- 弹性空间，让圆形居中偏上 -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="0.3" />

    <!-- 状态大字 -->
    <TextView
        android:id="@+id/tv_state_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="16:8 轻断食"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <!-- 圆形进度视图 -->
    <com.fasting.app.CircularProgressView
        android:id="@+id/circular_progress"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp" />

    <!-- 倒计时标签 -->
    <TextView
        android:id="@+id/tv_countdown_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="点击开始，进入16小时断食"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginTop="8dp" />

    <!-- 弹性空间 -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="0.5" />

    <!-- 按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- 开始断食按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="开始断食"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/fasting_color" />

        <!-- 重置按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="120dp"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:text="重置"
            android:textColor="@color/fasting_color"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            app:strokeColor="@color/fasting_color" />

    </LinearLayout>

    <!-- 底部弹性空间 -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="0.3" />

</LinearLayout>
